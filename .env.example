# Tillandsia — environment variables
# Copy to .env.local and fill in. NEVER commit real values.

# --- Supabase (Phase 0/1) — from Supabase → Settings → API ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # secret — server only

# --- Recognition (Phase 2A) — Claude vision ---
ANTHROPIC_API_KEY=                  # used by the upload recognition job

# --- Web Push + Cron (Phase 2B) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=                        # protects /api/cron/reminders

